              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[using System;
using System.IO;
using System.Windows.Forms;
using Microsoft.SqlServer.Dts.Runtime;

namespace ST_23b14b6d0d7d41f6b2d4b6d8b3e5f1a2
{
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        #region VSTA generated code
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

        public void Main()
        {
            try
            {
                string rutaEntrada = Dts.Variables["User::RutaEntrada"].Value.ToString();
                string[] archivosRequeridos = { "Clientes.csv", "Productos.csv", "Ventas.csv" };
                bool todosExisten = true;
                string mensaje = "";

                foreach (string archivo in archivosRequeridos)
                {
                    string rutaCompleta = Path.Combine(rutaEntrada, archivo);
                    if (!File.Exists(rutaCompleta))
                    {
                        todosExisten = false;
                        mensaje += "Falta el archivo: " + archivo + "\n";
                    }
                }

                if (!todosExisten)
                {
                    MessageBox.Show(mensaje, "Error de validación", MessageBoxButtons.OK, MessageBoxIcon.Error);
                    Dts.TaskResult = (int)ScriptResults.Failure;
                }
                else
                {
                    Dts.TaskResult = (int)ScriptResults.Success;
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "ValidarArchivos", ex.Message, "", 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
    }
}]]></ProjectItem>
