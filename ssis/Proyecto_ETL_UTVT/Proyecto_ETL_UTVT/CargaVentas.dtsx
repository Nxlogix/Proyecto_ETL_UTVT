          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{5234465F-C12F-40C4-B50E-5EB1FFE88A78}"
              SQLTask:SqlStatementSource="INSERT INTO LogProceso&#xA;(&#xA;NombrePaquete,&#xA;FechaInicio,&#xA;Estatus&#xA;)&#xA;&#xA;VALUES&#xA;&#xA;(&#xA;'CargaVentas',&#xA;GETDATE(),&#xA;'EN PROCESO'&#xA;)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
