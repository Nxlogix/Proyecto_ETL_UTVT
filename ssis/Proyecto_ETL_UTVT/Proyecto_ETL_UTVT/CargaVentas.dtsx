          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{5234465F-C12F-40C4-B50E-5EB1FFE88A78}"
              SQLTask:SqlStatementSource="UPDATE LogProceso&#xA;&#xA;SET&#xA;&#xA;FechaFin=GETDATE(),&#xA;&#xA;DuracionSegundos=DATEDIFF&#xA;(&#xA;SECOND,&#xA;FechaInicio,&#xA;GETDATE()&#xA;),&#xA;&#xA;Estatus='FINALIZADO'&#xA;&#xA;WHERE&#xA;&#xA;IdProceso=&#xA;(&#xA;SELECT MAX(IdProceso)&#xA;&#xA;FROM LogProceso&#xA;)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
